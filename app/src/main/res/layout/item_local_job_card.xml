<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- IMAGE + OVERLAY -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/job_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/local_job_image"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_primary_gradient" />

            <!-- Glass overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#CCFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                    android:id="@+id/job_business_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/job_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        app:drawableStartCompat="@drawable/ic_near_me_24"
                        android:drawablePadding="6dp"
                        app:drawableTint="@color/text_secondary"
                        android:gravity="end|center_vertical"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/job_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/job_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- INFO GRID: single column, one row per field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/bg_info_grid_rounded_top">

            <!-- Hidden: preserve job_business_name variable -->
<!--            <TextView-->
<!--                android:id="@+id/job_business_name"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:visibility="gone" />-->

            <!-- Job Description -->
            <TextView
                android:id="@+id/job_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="24dp"
                app:drawableStartCompat="@drawable/ic_work_outline_24"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primary_dark"
                android:gravity="center_vertical"
                android:textColor="@color/primary_dark"
                android:textSize="13sp" />

            <!-- Pay -->
            <TextView
                android:id="@+id/job_pay_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="24dp"
                app:drawableStartCompat="@drawable/ic_payments_24"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primary_dark"
                android:gravity="center_vertical"
                android:textColor="@color/primary_dark"
                android:textSize="13sp" />

            <!-- Address -->
            <TextView
                android:id="@+id/job_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="24dp"
                app:drawableStartCompat="@drawable/ic_location_on_24"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primary_dark"
                android:gravity="center_vertical"
                android:textColor="@color/primary_dark"
                android:textSize="13sp" />

            <!-- WhatsApp -->
            <TextView
                android:id="@+id/job_whatsapp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="24dp"
                app:drawableStartCompat="@drawable/ic_chat_24"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primary_dark"
                android:gravity="center_vertical"
                android:textColor="@color/primary_dark"
                android:textSize="13sp" />

            <!-- Phone -->
            <TextView
                android:id="@+id/job_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="24dp"
                app:drawableStartCompat="@drawable/ic_call_24"
                android:drawablePadding="8dp"
                app:drawableTint="@color/primary_dark"
                android:gravity="center_vertical"
                android:textColor="@color/primary_dark"
                android:textSize="13sp" />

            <!-- Expires: Bottom Right -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/job_expires_at"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_schedule_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/error"
                    android:gravity="center_vertical"
                    android:textColor="@color/error"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
