<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- IMAGE + OVERLAY -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/job_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/local_job_image"
                android:scaleType="centerInside"
                android:src="@drawable/ic_map_black_24dp"
                android:background="#E0E0E0" />

            <!-- Glass overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#CCFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/job_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/job_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        app:drawableStartCompat="@drawable/ic_near_me_24"
                        android:drawablePadding="6dp"
                        app:drawableTint="#666"
                        android:gravity="end|center_vertical"
                        android:textColor="#666" />

                </LinearLayout>

                <TextView
                    android:id="@+id/job_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#666"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

        </FrameLayout>

        <!-- INFO GRID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/bg_info_grid_rounded_top">

            <!-- Hidden: preserve job_business_name variable -->
            <TextView
                android:id="@+id/job_business_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Row 1: Type and Pay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/job_type"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_work_outline_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#666"
                    android:gravity="center_vertical"
                    android:textColor="#333"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/job_pay_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_payments_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#666"
                    android:gravity="center_vertical"
                    android:textColor="#333"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Row 2: Address and Distance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/job_address"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_location_on_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#666"
                    android:gravity="center_vertical"
                    android:textColor="#333"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/job_distance_small"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_near_me_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#666"
                    android:gravity="center_vertical"
                    android:textColor="#666"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Row 3: WhatsApp and Phone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/job_whatsapp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_chat_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#666"
                    android:gravity="center_vertical"
                    android:textColor="#6200EE"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/job_phone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_call_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#666"
                    android:gravity="center_vertical"
                    android:textColor="#333"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Expires: Bottom Right -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/job_expires_at"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="24dp"
                    app:drawableStartCompat="@drawable/ic_schedule_24"
                    android:drawablePadding="6dp"
                    app:drawableTint="#FFB6B6"
                    android:gravity="center_vertical"
                    android:textColor="#FFB6B6"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
