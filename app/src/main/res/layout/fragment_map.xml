<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map_fragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/map_loading_indicator"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="12dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/map_controls_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/button_current_location"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_map_control_button"
            android:contentDescription="@string/title_map"
            android:padding="12dp"
            android:src="@drawable/ic_near_me_24"
            app:tint="@color/primary_dark" />

        <ImageButton
            android:id="@+id/button_zoom_in"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_map_control_button"
            android:contentDescription="@string/map_zoom_in"
            android:padding="12dp"
            android:src="@drawable/ic_add_24"
            app:tint="@color/primary_dark" />

        <ImageButton
            android:id="@+id/button_zoom_out"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_map_control_button"
            android:contentDescription="@string/map_zoom_out"
            android:padding="12dp"
            android:src="@drawable/ic_remove_24"
            app:tint="@color/primary_dark" />

    </LinearLayout>

    <include
        android:id="@+id/place_bottom_sheet"
        layout="@layout/bottom_sheet_place_details" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/map_nav_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?android:attr/windowBackground"
        app:menu="@menu/bottom_nav_menu" />

    <!-- Second sheet: Job Apply — declared last so it draws on top of the nav bar, no backdrop -->
    <LinearLayout
        android:id="@+id/apply_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_bottom_sheet_top_rounded"
        android:clickable="true"
        android:elevation="24dp"
        android:focusable="true"
        android:orientation="vertical"
        android:translationZ="24dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/apply_sheet_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

